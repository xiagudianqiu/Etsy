# Supabase 配置（多用户改造必需）
# 复制本文件为 .env.local 并填入你的 Supabase 项目值
# https://supabase.com/dashboard → 你的项目 → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# 注：以下变量仅在 Vercel 部署时配置，本地无需
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# ADMIN_EMAIL=your-admin-email@example.com   # CSV 自动备份接收方
# CRON_SECRET=your-random-secret
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service-role-key
